# Server Environment Variables
PORT=5000
NODE_ENV=development

# Database (use 'postgres' for Docker, 'localhost' for local)
DATABASE_URL=postgresql://civic:civicpulse123@localhost:5432/civicpulse

# Redis
REDIS_URL=redis://localhost:6379

# JWT (generate with: openssl rand -hex 32)
JWT_SECRET=your-64-char-hex-secret-here
JWT_REFRESH_SECRET=your-64-char-hex-refresh-secret-here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AI Service
AI_SERVICE_URL=http://localhost:8000

# Groq AI (get key from https://console.groq.com)
GROQ_API_KEY=your-groq-api-key-here

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# Email (optional — Ethereal auto-created in dev if not set)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_FROM=CivicPulse <noreply@civicpulse.com>

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173
